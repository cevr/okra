{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "anyUnknownInErrorContext": "error",
          "deterministicKeys": "error",
          "extendsNativeError": "error",
          "importFromBarrel": "warning",
          "instanceOfSchema": "error",
          "missedPipeableOpportunity": "suggestion",
          "nodeBuiltinImport": "error",
          "serviceNotAsClass": "warning",
          "strictBooleanExpressions": "error",
          "strictEffectProvide": "error"
        }
      }
    ],
    "types": ["bun"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"]
}
