{
  "name": "@cvr/okra",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cevr/okra"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --tsconfig tsconfig.json --config .oxlintrc.json src/ tests/",
    "lint:fix": "oxlint --tsconfig tsconfig.json --config .oxlintrc.json --fix src/ tests/",
    "fmt": "oxfmt --write src/ scripts/ tests/",
    "fmt:check": "oxfmt --check src/ scripts/ tests/",
    "test": "bun test",
    "gate": "concurrently -g 'bun run typecheck' 'bun run lint' 'bun run fmt:check' 'bun test' && bun run build",
    "prepare": "effect-language-service patch && lefthook install",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "effect": "4.0.0-beta.29",
    "@effect/platform-bun": "4.0.0-beta.29"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/language-service": "^0.79.0",
    "@types/bun": "^1.3.9",
    "concurrently": "^9.2.1",
    "effect-bun-test": "^0.2.1",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3"
  }
}
